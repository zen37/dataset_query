# Shared CLI defaults
QUERY_OUTPUT=table
# Default loop count when --interval-seconds is used and --iterations is omitted.
# Leave blank to keep running until you stop it manually.
QUERY_LOOP_ITERATIONS=10

# DuckDB / ADLS
DUCKDB_DATABASE=:memory:
DUCKDB_SQL=
ADLS_AUTH_MODE=service_principal
ADLS_URI=abfss://myaccount.dfs.core.windows.net/myfilesystem/path/*.parquet
ADLS_SCOPE=abfss://myaccount.dfs.core.windows.net/myfilesystem/
AZURE_STORAGE_ACCOUNT=myaccount
AZURE_CONNECTION_STRING=
AZURE_CREDENTIAL_CHAIN=cli;env

# Shared Azure app credentials used by ADLS service principal auth and ADX.
AZURE_TENANT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000
AZURE_CLIENT_SECRET=replace-me

# MotherDuck
MOTHERDUCK_DATABASE=my_db
MOTHERDUCK_TOKEN=
# Optional: set to true only if you explicitly need MotherDuck SaaS mode.
MOTHERDUCK_SAAS_MODE=false
# Optional: set to 0s to avoid keeping the MotherDuck DB instance warm between runs.
MOTHERDUCK_DBINSTANCE_INACTIVITY_TTL=0s

# Azure Data Explorer
ADX_CLUSTER_URL=https://mycluster.region.kusto.windows.net
ADX_DATABASE=mydatabase
